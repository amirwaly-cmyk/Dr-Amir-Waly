---
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex } = Astro.props;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#4d72a6" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Work+Sans:wght@400;500;600;700&display=swap"
    />
    <SEO title={title} description={description} noindex={noindex} />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col antialiased bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded focus:bg-clinic-800 focus:px-3 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>

    <div class="scroll-progress-bar" transition:persist aria-hidden="true"></div>

    <!-- Sentinel used by IntersectionObserver to detect when the header should shrink -->
    <div id="header-sentinel" class="h-px" transition:persist aria-hidden="true"></div>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      // Re-runs on initial load AND on every Astro view-transition navigation.
      const reduced = () =>
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initReveals() {
        const els = document.querySelectorAll<HTMLElement>(
          '.reveal:not(.is-visible), .hero-reveal:not(.is-visible)'
        );
        if (reduced() || !('IntersectionObserver' in window)) {
          els.forEach(el => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          entries => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        els.forEach(el => io.observe(el));

        // Above-the-fold hero elements should reveal on next frame, not on
        // intersection (they start in view, and IntersectionObserver can
        // fire fractionally late on initial load).
        requestAnimationFrame(() => {
          document
            .querySelectorAll<HTMLElement>('.hero-reveal:not(.is-visible)')
            .forEach(el => el.classList.add('is-visible'));
        });
      }

      function initHeaderShrink() {
        if ((window as any).__headerShrinkInit) return;
        (window as any).__headerShrinkInit = true;
        const observer = new IntersectionObserver(
          ([entry]) => {
            const header = document.querySelector<HTMLElement>('[data-shrinkable-header]');
            if (header) header.dataset.scrolled = String(!entry.isIntersecting);
          },
          { threshold: 0, rootMargin: '0px' }
        );
        const sentinel = document.getElementById('header-sentinel');
        if (sentinel) observer.observe(sentinel);
      }

      function initScrollProgress() {
        // Modern browsers use CSS scroll-driven animation; skip the JS fallback.
        if (CSS.supports('animation-timeline: scroll()')) return;
        if ((window as any).__scrollProgressInit) return;
        (window as any).__scrollProgressInit = true;
        if (reduced()) return;
        const update = () => {
          const bar = document.querySelector<HTMLDivElement>('.scroll-progress-bar');
          if (!bar) return;
          const max = Math.max(
            1,
            document.documentElement.scrollHeight - window.innerHeight
          );
          bar.style.transform = `scaleX(${Math.min(1, window.scrollY / max)})`;
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update, { passive: true });
      }

      initReveals();
      initScrollProgress();
      initHeaderShrink();
      document.addEventListener('astro:page-load', () => {
        initReveals();
        // Scroll progress + header shrink are single global listeners — no re-init needed.
      });
    </script>
  </body>
</html>
