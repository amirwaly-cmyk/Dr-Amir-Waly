---
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import { site } from '@/config/site';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; href: string }>;
  article?: {
    headline: string;
    datePublished: string;
    dateModified?: string;
    wordCount?: number;
    section?: string;
  };
  image?: string;
}

const { title, description, noindex, breadcrumbs, article, image } = Astro.props;
const plausibleEnabled = site.analytics.plausibleEnabled;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#4d72a6" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Work+Sans:wght@400;500;600;700&display=swap"
    />
    <SEO
      title={title}
      description={description}
      noindex={noindex}
      breadcrumbs={breadcrumbs}
      article={article}
      image={image}
    />
    <ClientRouter />
    {plausibleEnabled && (
      <>
        {/* Privacy-friendly analytics by Plausible.
            SRI integrity hash pins the script content — if the served
            file ever changes (e.g. CDN compromise), the browser will
            refuse to execute it. Hash needs to be regenerated whenever
            Plausible legitimately updates the tracker. */}
        <script
          async
          is:inline
          src="https://plausible.io/js/pa-DMhWriKclqnInTMr6YqgU.js"
          integrity="sha384-YEXihzUZQR/E78WHG85+T8MgyoL1SQdAJqrMbxJyjsB3l50zeLIxs4yxh0G6muh5"
          crossorigin="anonymous"
        ></script>
        <script is:inline>
          window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
          plausible.init()
        </script>
        {/* Count Astro view-transition navigations as separate pageviews */}
        <script is:inline>
          document.addEventListener('astro:page-load', function(){
            if (window.plausible && document.visibilityState === 'visible') {
              window.plausible('pageview');
            }
          });
        </script>
      </>
    )}
  </head>
  <body class="flex min-h-screen flex-col antialiased bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded focus:bg-clinic-800 focus:px-3 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>

    <div class="scroll-progress-bar" transition:persist aria-hidden="true"></div>

    <!-- Sentinel used by IntersectionObserver to detect when the header should shrink -->
    <div id="header-sentinel" class="h-px" transition:persist aria-hidden="true"></div>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <!-- =====================================================================
         Site search — Pagefind static-site search.
         Indexed at build time (npm run build runs pagefind after astro build).
         The overlay is hidden by default; opened by the search button in the
         Header or by Ctrl+K / Cmd+K from anywhere.
         ===================================================================== -->
    <div
      id="search-overlay"
      class="fixed inset-0 z-50 hidden bg-ink-900/40 backdrop-blur-sm"
      data-search-overlay
      transition:persist
      aria-hidden="true"
    >
      <div class="mx-auto mt-[10vh] w-full max-w-2xl px-4">
        <div class="bg-white border border-ink-200/70 shadow-2xl shadow-clinic-900/20">
          <div class="flex items-center justify-between px-4 py-3 border-b border-ink-100">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-ink-500">
              Search this site
            </p>
            <button
              type="button"
              class="inline-flex items-center gap-1.5 text-[12px] text-ink-500 hover:text-ink-800 transition-colors"
              data-search-close
              aria-label="Close search"
            >
              <span>Esc</span>
              <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 3l6 6M9 3l-6 6" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <div id="search-ui" class="p-4"></div>
        </div>
      </div>
    </div>
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <script>
      // Re-runs on initial load AND on every Astro view-transition navigation.
      const reduced = () =>
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initReveals() {
        const els = document.querySelectorAll<HTMLElement>(
          '.reveal:not(.is-visible), .hero-reveal:not(.is-visible)'
        );
        if (reduced() || !('IntersectionObserver' in window)) {
          els.forEach(el => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          entries => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        els.forEach(el => io.observe(el));

        // Above-the-fold hero elements should reveal on next frame, not on
        // intersection (they start in view, and IntersectionObserver can
        // fire fractionally late on initial load).
        requestAnimationFrame(() => {
          document
            .querySelectorAll<HTMLElement>('.hero-reveal:not(.is-visible)')
            .forEach(el => el.classList.add('is-visible'));
        });
      }

      function initHeaderShrink() {
        if ((window as any).__headerShrinkInit) return;
        (window as any).__headerShrinkInit = true;
        const observer = new IntersectionObserver(
          ([entry]) => {
            const header = document.querySelector<HTMLElement>('[data-shrinkable-header]');
            if (header) header.dataset.scrolled = String(!entry.isIntersecting);
          },
          { threshold: 0, rootMargin: '0px' }
        );
        const sentinel = document.getElementById('header-sentinel');
        if (sentinel) observer.observe(sentinel);
      }

      function initScrollProgress() {
        // Modern browsers use CSS scroll-driven animation; skip the JS fallback.
        if (CSS.supports('animation-timeline: scroll()')) return;
        if ((window as any).__scrollProgressInit) return;
        (window as any).__scrollProgressInit = true;
        if (reduced()) return;
        const update = () => {
          const bar = document.querySelector<HTMLDivElement>('.scroll-progress-bar');
          if (!bar) return;
          const max = Math.max(
            1,
            document.documentElement.scrollHeight - window.innerHeight
          );
          bar.style.transform = `scaleX(${Math.min(1, window.scrollY / max)})`;
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update, { passive: true });
      }

      function initSearch() {
        if ((window as any).__searchInit) return;
        const overlay = document.querySelector<HTMLDivElement>('[data-search-overlay]');
        if (!overlay) return;

        const open = () => {
          overlay.classList.remove('hidden');
          overlay.setAttribute('aria-hidden', 'false');
          const input = overlay.querySelector<HTMLInputElement>('input.pagefind-ui__search-input');
          input?.focus();
        };
        const close = () => {
          overlay.classList.add('hidden');
          overlay.setAttribute('aria-hidden', 'true');
        };

        // Bind delegated triggers (search button is inside the persisted header)
        document.addEventListener('click', (e) => {
          const t = e.target as Element | null;
          if (!t) return;
          if (t.closest('[data-search-open]')) {
            e.preventDefault();
            open();
            return;
          }
          if (t.closest('[data-search-close]')) {
            close();
            return;
          }
          if (overlay && t === overlay) close(); // click on backdrop
        });

        document.addEventListener('keydown', (e) => {
          // Cmd+K / Ctrl+K opens search
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            open();
          } else if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
            close();
          }
        });

        // Load PagefindUI script + initialise once
        const PagefindUIClass = (window as any).PagefindUI;
        const mount = () => {
          new (window as any).PagefindUI({
            element: '#search-ui',
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            translations: {
              placeholder: 'Search the practice site…',
            },
          });
        };
        if (PagefindUIClass) {
          mount();
        } else {
          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = () => { try { mount(); } catch {} };
          document.head.appendChild(script);
        }

        (window as any).__searchInit = true;
      }

      initReveals();
      initScrollProgress();
      initHeaderShrink();
      initSearch();
      document.addEventListener('astro:page-load', () => {
        initReveals();
        // Scroll progress, header shrink, and search are single global
        // listeners — no re-init needed.
      });
    </script>
  </body>
</html>
