---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site } from '@/config/site';

const policies = [
  {
    href: '/private-gp-explained',
    title: 'Private GP, Explained Honestly',
    body: 'A plain-spoken first-person essay on why this practice bills the way it does — what private GP care actually buys, why bulk-billing economics are collapsing, and what a longer consultation enables clinically.',
  },
  {
    href: '/patient-rights',
    title: 'Patient Rights & Responsibilities',
    body: 'Aligned with the Australian Charter of Healthcare Rights (2nd edition). Your rights as a patient, your responsibilities, and how the practice approaches consent and access to records.',
  },
  {
    href: '/fees-and-billing',
    title: 'Fees & Billing Policy',
    body: 'A private-billing practice with Medicare rebates where eligible. Twelve standing policies including informed financial consent, the 24-hour cancellation policy, and why specific fees are not published online.',
  },
  {
    href: '/communication-and-results',
    title: 'Communication & Results',
    body: 'How investigation results are communicated, recalls and reminders, repeat prescriptions, specialist correspondence, and the role of SMS and email.',
  },
  {
    href: '/clinical-photography',
    title: 'Clinical Photography & Imaging',
    body: 'When clinical photographs and dermoscopic images are taken, how consent is obtained, how images are stored and accessed, and the strict exclusion of marketing or advertising use.',
  },
  {
    href: '/complaints',
    title: 'Complaints & Feedback',
    body: 'How to raise a concern, what to expect in response, and the independent external avenues available (HaDSCO Western Australia, AHPRA, OAIC).',
  },
  {
    href: '/open-disclosure',
    title: 'Open Disclosure',
    body: 'The practice’s commitment to honest, timely communication with patients and families when something goes wrong in healthcare, consistent with the Australian Open Disclosure Framework.',
  },
  {
    href: '/privacy',
    title: 'Privacy Policy',
    body: 'How personal and health information is collected, held, used, and disclosed, in line with the Privacy Act 1988 (Cth) and the Australian Privacy Principles. Includes the OAIC complaint pathway.',
  },
  {
    href: '/disclaimer',
    title: 'Website & Medical Information Disclaimer',
    body: 'The website is general information only. No doctor-patient relationship is created through the site. In a medical emergency, call 000.',
  },
];
---
<BaseLayout
  title={`Practice Policies — ${site.doctorName}`}
  description={`The full set of practice policies for ${site.doctorName}'s independent specialist GP practice — patient rights, complaints, privacy, open disclosure, clinical photography, fees and billing, communication and results, and website disclaimer.`}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Practice policies', href: '/policies' },
  ]}
>
  <section class="border-b border-ink-100 bg-paper">
    <Container class="py-24 sm:py-32 lg:py-36">
      <div class="reveal">
        <p class="eyebrow">Practice policies</p>
        <h1 class="display-xl mt-7 text-[2.6rem] sm:text-6xl lg:text-[4.5rem] max-w-4xl">
          The policies that govern this practice.
        </h1>
        <p class="lead mt-8 max-w-2xl">
          A clear, public set of policies covering patient rights, complaints,
          privacy, open disclosure, clinical photography, fees, communication,
          and the use of this website. Each policy is published in full and
          updated as guidance evolves.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-20 sm:py-24">
    <Container>
      <ul class="grid gap-px bg-ink-100 border border-ink-100 sm:grid-cols-2">
        {policies.map((p, i) => (
          <li class="bg-white">
            <a href={p.href} class="group block p-8 sm:p-10 transition-colors hover:bg-paper-soft h-full">
              <span class="numeral text-sm tabular-nums">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="mt-4 font-serif text-xl text-ink-900 leading-snug">
                {p.title}
              </h2>
              <p class="mt-3 text-[15px] leading-relaxed text-ink-600">{p.body}</p>
              <span class="mt-5 inline-flex items-center gap-2 text-[0.92rem] font-medium text-clinic-700">
                <span class="border-b border-clinic-300 group-hover:border-clinic-700 transition-colors">
                  Read the policy
                </span>
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>
</BaseLayout>
