---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site } from '@/config/site';

const services = [
  {
    title: 'General Medicine',
    body: 'Consultations for new and ongoing health concerns, chronic disease management, preventive health, men&rsquo;s health, mental health, immunisations, and standard short-term medical certificates where clinically appropriate. <strong class="text-ink-800">Workers&rsquo; compensation, third-party insurance, and medico-legal reports are not provided by this practice</strong> &mdash; please ask reception for a referral to an appropriately qualified colleague.',
  },
  {
    title: 'Skin Cancer Checks',
    body: 'Full skin examinations supported by dermoscopy &mdash; a magnified, polarised examination of skin lesions. Recommended periodically based on individual risk factors including personal and family history of skin cancer, multiple atypical naevi, and cumulative sun exposure. See the <a class="link-quiet text-ink-900" href="/skin-cancer-surgery">skin cancer medicine and surgery</a> page for full information.',
  },
  {
    title: 'Skin Cancer Surgery',
    body: 'Biopsy and surgical excision of skin lesions, including basal cell carcinoma, squamous cell carcinoma, and selected melanomas, performed in the clinic under local anaesthetic with closure appropriate to the site. Complex lesions, or lesions on cosmetically sensitive sites, are referred to a dermatologist or plastic surgeon where appropriate.',
  },
  {
    title: 'Non-Surgical Cosmetic Medicine',
    body: 'Consultation-based non-surgical cosmetic treatments for adult patients &mdash; including anti-wrinkle injection treatments, dermal fillers, and laser treatments. A separate consultation and a minimum seven-day cooling-off period are required before any treatment, in line with the Medical Board of Australia&rsquo;s 2023 guidelines. See the <a class="link-quiet text-ink-900" href="/cosmetic-medicine">cosmetic medicine</a> page.',
  },
  {
    title: 'Joint Injections',
    body: 'Injections for musculoskeletal joint conditions, with a particular focus on the knee &mdash; including <strong class="text-ink-800">corticosteroid (cortisone)</strong>, <strong class="text-ink-800">hyaluronic acid</strong> (viscosupplementation for osteoarthritis), and <strong class="text-ink-800">platelet-rich plasma (PRP)</strong> injections. Each treatment suits different clinical pictures and stages of disease; suitability, expected benefit, reasonable alternatives, and the relevant risks are discussed in detail before any injection is agreed.',
  },
  {
    title: 'Soft-Tissue Injections',
    body: '<strong class="text-ink-800">Corticosteroid</strong> and <strong class="text-ink-800">platelet-rich plasma (PRP)</strong> injections for common soft-tissue problems such as tennis elbow (lateral epicondylitis), golfer&rsquo;s elbow, shoulder tendinopathy, and other peripheral tendon and bursal conditions. Suitability and expected benefit are discussed alongside reasonable alternatives &mdash; including activity modification, physiotherapy, and bracing &mdash; before any injection is agreed.',
  },
  {
    title: 'Contraceptive Implant &mdash; Insertion &amp; Removal',
    body: 'Insertion and removal of the <strong class="text-ink-800">subdermal contraceptive implant (etonogestrel)</strong> &mdash; a small, flexible rod placed under the skin of the inner upper arm that provides up to three years of contraception. Both insertion and removal are performed in the clinic under local anaesthetic. Suitability is discussed in consultation, including expected effects, possible side effects, contraindications, and reasonable alternative contraceptive options. Replacement and earlier removal are both available.',
  },
];
---
<BaseLayout
  title={`Clinical Services — Dr Amir Waly, Specialist GP ${site.address.suburb}`}
  description={`General medicine, skin cancer checks and surgery, non-surgical cosmetic medicine, knee injections (cortisone, hyaluronic acid, PRP), and soft-tissue injections for tennis elbow and similar conditions — provided by ${site.doctorName}, independent specialist GP, in ${site.address.suburb}, Perth.`}
  image="/og/services.png"
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/services' },
  ]}
>
  <section class="border-b border-ink-100 bg-paper">
    <Container class="py-24 sm:py-32 lg:py-36">
      <div class="reveal">
      <p class="eyebrow">Clinical services</p>
      <h1 class="display-xl mt-7 text-[2.6rem] sm:text-6xl lg:text-[4.5rem] max-w-4xl">
        Considered consultations for the breadth of general practice.
      </h1>
      <p class="lead mt-7 max-w-2xl">
        A summary of the consultations and services available. If your concern
        isn&rsquo;t listed, please call the clinic &mdash; we&rsquo;re happy to advise
        whether an appointment is appropriate.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3 text-[13px]">
        <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-ink-500">Areas of interest:</span>
        <a href="/skin-cancer-surgery" class="link-quiet text-ink-800">Skin cancer surgery</a>
        <span class="text-accent" aria-hidden="true">&middot;</span>
        <a href="/cosmetic-medicine" class="link-quiet text-ink-800">Cosmetic medicine</a>
        <span class="text-accent" aria-hidden="true">&middot;</span>
        <a href="/laser-medicine" class="link-quiet text-ink-800">Laser medicine</a>
      </div>
      </div>
    </Container>
  </section>

  <section class="py-20 sm:py-24">
    <Container>
      <ul class="grid gap-px bg-ink-100 border border-ink-100 sm:grid-cols-2">
        {services.map((s, i) => {
          // Slug from title — used as the anchor id so the header dropdown
          // can deep-link to specific services (e.g. /services#joint-injections).
          const id = s.title
            .replace(/&[^;]+;/g, '-')
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '');
          return (
            <li id={id} class="relative bg-white p-8 sm:p-10 transition-colors hover:bg-paper-soft scroll-mt-32">
              <span class="numeral text-sm tabular-nums">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="mt-4 font-serif text-xl text-ink-900 leading-snug" set:html={s.title} />
              <p class="mt-3 text-[15.5px] leading-relaxed text-ink-600" set:html={s.body} />
            </li>
          );
        })}
      </ul>
    </Container>
  </section>

  <section class="bg-paper py-20 sm:py-24">
    <Container size="narrow">
      <p class="eyebrow">Fees &amp; billing</p>
      <h2 class="display mt-5 text-3xl sm:text-4xl">
        Private practice. Medicare rebates where eligible.
      </h2>
      <p class="mt-6 text-ink-600 leading-relaxed text-lg">
        This is a fully private-billing practice. Where your consultation or
        procedure is eligible under the Medicare Benefits Schedule, a rebate
        can be claimed; reception can process it at the end of your visit.
      </p>
      <p class="mt-5 text-ink-600 leading-relaxed">
        Specific fees are not published on this website &mdash; an accurate
        fee can only be quoted in the context of your booking. Please contact
        reception for a fee estimate, the relevant Medicare rebate, and the
        expected out-of-pocket gap before you book.
      </p>
      <p class="mt-5 text-ink-600 leading-relaxed">
        For a plain-spoken explanation of <em>why</em> this practice bills
        the way it does, see
        <a class="link-quiet text-ink-900" href="/private-gp-explained">Private
        GP, explained honestly</a>.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/fees-and-billing"
          class="group inline-flex items-center gap-2 rounded-sm border border-ink-300 bg-white px-5 py-3 text-[0.88rem] font-medium tracking-wide text-ink-800 transition-colors hover:border-clinic-700 hover:text-clinic-800"
        >
          <span>Read the full fees &amp; billing policy</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
        </a>
        <a
          href={site.phoneHref}
          class="inline-flex items-center rounded-sm bg-clinic-800 px-5 py-3 text-[0.88rem] font-medium tracking-wide text-white transition-colors hover:bg-clinic-900"
        >
          Call reception for a fee estimate
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
