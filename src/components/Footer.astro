---
import Container from './Container.astro';
import { site } from '@/config/site';

const year = new Date().getFullYear();
const quals = site.qualifications.split(',').map(s => s.trim()).join('  ·  ');
const hasEmail = !site.email.startsWith('[');
---
<footer class="mt-28 border-t border-ink-100 bg-paper-soft">
  <Container class="py-16">
    <div class="grid gap-12 md:grid-cols-12">

      <!-- ============================================================ -->
      <!-- COLUMN 1 — The practitioner                                  -->
      <!-- ============================================================ -->
      <div class="md:col-span-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-ink-400">
          The practitioner
        </p>
        <p class="mt-4 font-serif text-2xl font-medium tracking-tight text-clinic-800">
          {site.doctorName}
        </p>
        <p class="mt-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-ink-500">
          {quals}
        </p>
        <p class="mt-5 max-w-sm text-[15px] leading-relaxed text-ink-600">
          {site.practiceDescriptor}, providing consultancy services to
          medical centres and urgent care clinics, national telehealth
          services such as Healthdirect, on-site care to residents of
          selected residential aged-care facilities, advisory roles with
          medical technology startups, and involvement in Level 3
          supervision of International Medical Graduates.
        </p>
        <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-1">
          <li><a class="link-quiet text-[13px]" href="/insights">Insights</a></li>
          <li><a class="link-quiet text-[13px]" href="/faqs">FAQs</a></li>
          <li><a class="link-quiet text-[13px]" href="/policies">Practice policies</a></li>
        </ul>
      </div>

      <!-- ============================================================ -->
      <!-- COLUMN 2 — Consulting venue (one of several)                 -->
      <!-- ============================================================ -->
      <div class="md:col-span-3 md:border-l md:border-ink-200/70 md:pl-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-ink-400">
          Consulting venue &mdash; {site.address.suburb}
        </p>
        <p class="mt-4 font-serif text-[17px] leading-snug text-ink-900">
          {site.clinicName}
        </p>
        <address class="not-italic mt-2 text-[14.5px] leading-relaxed text-ink-700">
          <div>{site.address.line1}</div>
          {site.address.line2 && <div>{site.address.line2}</div>}
          <div>{site.address.suburb}, {site.address.state} {site.address.postcode}</div>
        </address>
        <ul class="mt-4 space-y-1 text-[14.5px] text-ink-700">
          <li>
            <span class="text-[11px] uppercase tracking-[0.18em] text-ink-400 mr-2">Phone</span>
            <a class="link-quiet tabular-nums" href={site.phoneHref}>{site.phone}</a>
          </li>
          <li>
            <span class="text-[11px] uppercase tracking-[0.18em] text-ink-400 mr-2">Fax</span>
            <span class="tabular-nums">{site.fax}</span>
          </li>
        </ul>
        <p class="mt-4 text-[12px] leading-relaxed text-ink-500 max-w-xs">
          One of {site.doctorShortName}&rsquo;s consulting venues.
          Other engagements (telehealth via Healthdirect, urgent care
          clinics, residential aged-care visits, medtech advisory) are
          arranged through those services directly &mdash; see the
          <a class="link-quiet text-ink-700" href="/about">About page</a>.
        </p>
      </div>

      <!-- ============================================================ -->
      <!-- COLUMN 3 — Registered business entity                        -->
      <!-- ============================================================ -->
      <div class="md:col-span-4 md:border-l md:border-ink-200/70 md:pl-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-ink-400">
          Registered business
        </p>
        <p class="mt-4 font-serif text-[17px] leading-snug text-ink-900">
          {site.business.name}
        </p>
        <dl class="mt-3 grid grid-cols-12 gap-x-4 gap-y-1.5 text-[14px] text-ink-500 max-w-sm">
          <dt class="col-span-3 uppercase tracking-[0.18em] text-[10px] font-semibold text-ink-400 pt-0.5">ABN</dt>
          <dd class="col-span-9 text-ink-700 tabular-nums">{site.abn}</dd>
          <dt class="col-span-3 uppercase tracking-[0.18em] text-[10px] font-semibold text-ink-400 pt-0.5">AHPRA</dt>
          <dd class="col-span-9 text-ink-700 tabular-nums">{site.ahpraNumber}</dd>
          <dt class="col-span-3 uppercase tracking-[0.18em] text-[10px] font-semibold text-ink-400 pt-0.5">Office</dt>
          <dd class="col-span-9 text-ink-700 leading-snug">
            {site.business.address.line1}, {site.business.address.line2},<br/>
            {site.business.address.suburb} {site.business.address.state} {site.business.address.postcode}
          </dd>
          {hasEmail && (
            <>
              <dt class="col-span-3 uppercase tracking-[0.18em] text-[10px] font-semibold text-ink-400 pt-0.5">Email</dt>
              <dd class="col-span-9">
                <a class="link-quiet text-ink-700 break-all" href={site.emailHref}>{site.email}</a>
              </dd>
            </>
          )}
        </dl>
        <p class="mt-4 text-[12px] leading-relaxed text-ink-500 max-w-xs">
          Registered business entity through which the practice operates.
          The office address is not a patient-visit location, and the
          email is for administrative or non-clinical correspondence only
          &mdash; not for appointments, clinical questions, prescriptions,
          or results.
        </p>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-ink-200/70 pt-6 text-xs text-ink-500 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {site.doctorName}. All rights reserved.</p>
      <p class="max-w-xl sm:text-right">
        This website provides general information only and is not a substitute for medical advice.
        In an emergency call <strong class="text-ink-700 tabular-nums">000</strong>.
      </p>
    </div>
  </Container>
</footer>
