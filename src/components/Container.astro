---
type Size = 'narrow' | 'default' | 'wide';

interface Props {
  as?: 'div' | 'section' | 'header' | 'footer' | 'main' | 'article';
  class?: string;
  size?: Size;
}

const { as: Tag = 'div', class: className = '', size = 'default' as Size } = Astro.props;

const sizes: Record<Size, string> = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
};
---
<Tag class={`mx-auto w-full ${sizes[size as Size]} px-5 sm:px-8 ${className}`}>
  <slot />
</Tag>
